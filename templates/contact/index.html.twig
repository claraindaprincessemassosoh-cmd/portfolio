{% extends 'base.html.twig' %}

{% block title %}Contact — Clarainda Massosoh{% endblock %}

{% block body %}

<div class="contact-hdr">
  <h2>Contact</h2>
  <p>Disponible pour une alternance ou un stage en réseaux &amp; télécommunications</p>
</div>

<div class="contact-body">

  <div class="ccard">
    <div class="ccard-title">Coordonnées</div>

    <div class="citem">
      <div class="citem-icon"><i class="ti ti-brand-github" aria-hidden="true" style="color:#3b9eff;"></i></div>
      <div>
        <div class="citem-label">GitHub</div>
        <div class="citem-val">
          <a href="https://github.com/{{ github }}" target="_blank">{{ github }}</a>
        </div>
      </div>
    </div>

    <div class="citem">
      <div class="citem-icon"><i class="ti ti-map-pin" aria-hidden="true" style="color:#3b9eff;"></i></div>
      <div>
        <div class="citem-label">Localisation</div>
        <div class="citem-val">{{ localisation }}</div>
      </div>
    </div>

    <div class="citem">
      <div class="citem-icon"><i class="ti ti-school" aria-hidden="true" style="color:#3b9eff;"></i></div>
      <div>
        <div class="citem-label">Formation</div>
        <div class="citem-val">{{ formation }}</div>
      </div>
    </div>

    <div class="citem">
      <div class="citem-icon"><i class="ti ti-briefcase" aria-hidden="true" style="color:#22c55e;"></i></div>
      <div>
        <div class="citem-label">Recherche</div>
        <div class="citem-val" style="color:#4ade80;">Alternance / Stage réseau</div>
      </div>
    </div>

    <div style="margin-top: 12px;">
      <a href="https://github.com/{{ github }}" target="_blank" class="gh-banner">
        <div class="gh-icon"><i class="ti ti-brand-github" aria-hidden="true" style="font-size:20px;color:#3b9eff;"></i></div>
        <div>
          <div class="gh-label">Voir mes projets sur</div>
          <div class="gh-val">github.com/{{ github }}</div>
        </div>
      </a>
    </div>
  </div>

  <div class="ccard">
    <div class="ccard-title">Envoyer un message</div>
    <form class="form-area" action="#" method="post">
      <div class="form-row">
        <label class="form-label" for="nom">Nom</label>
        <input class="form-input" type="text" id="nom" name="nom" placeholder="Votre nom" required>
      </div>
      <div class="form-row">
        <label class="form-label" for="email">Email</label>
        <input class="form-input" type="email" id="email" name="email" placeholder="votre@email.com" required>
      </div>
      <div class="form-row">
        <label class="form-label" for="objet">Objet</label>
        <input class="form-input" type="text" id="objet" name="objet" placeholder="Proposition d'alternance...">
      </div>
      <div class="form-row">
        <label class="form-label" for="message">Message</label>
        <textarea class="form-textarea" id="message" name="message" placeholder="Votre message..."></textarea>
      </div>
      <button type="submit" class="form-btn">Envoyer</button>
    </form>
  </div>

</div>

{% endblock %}
