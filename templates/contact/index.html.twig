{% extends 'base.html.twig' %}

{% block title %}Contact — Clarainda Massosoh{% endblock %}

{% block body %}
  <div class="ccard">
    <div class="ccard-title">Envoyer un message</div>
    <form class="form-area" action="#" method="post">
      <div class="form-row">
        <label class="form-label" for="nom">Nom</label>
        <input class="form-input" type="text" id="nom" name="nom" placeholder="Votre nom" required>
      </div>
      <div class="form-row">
        <label class="form-label" for="email">Email</label>
        <input class="form-input" type="email" id="email" name="email" placeholder="votre@email.com" required>
      </div>
      <div class="form-row">
        <label class="form-label" for="objet">Objet</label>
        <input class="form-input" type="text" id="objet" name="objet" placeholder="Proposition d'alternance...">
      </div>
      <div class="form-row">
        <label class="form-label" for="message">Message</label>
        <textarea class="form-textarea" id="message" name="message" placeholder="Votre message..."></textarea>
      </div>
      <button type="submit" class="form-btn">Envoyer</button>
    </form>
  </div>

</div>

{% endblock %}
